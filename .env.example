PORT=5050
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Server-only Supabase credentials. Never expose the service-role key in Vite.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Paystack webhook verification and transaction verification.
PAYSTACK_SECRET_KEY=sk_test_replace_me

# Encrypts bank account numbers at rest (payout_accounts.account_number_cipher).
# REQUIRED for bank account setup and withdrawals. AES-256-CBC.
# Recommended format: 64-char hex (= 32 bytes). Generate with:
#   node scripts/generateEncryptionKey.js   (or: openssl rand -hex 32)
# Paste the value EXACTLY — no surrounding quotes, no trailing newline.
# MUST be identical across every environment sharing the same database.
ACCOUNT_ENCRYPTION_KEY=replace_with_64_char_hex
# Optional: set during a key rotation to the OLD key so existing records still
# decrypt while new records use ACCOUNT_ENCRYPTION_KEY. Remove once
# scripts/reencryptPayoutAccounts.js --apply has migrated all rows.
# ACCOUNT_ENCRYPTION_KEY_PREVIOUS=old_key_value

# Generate once with: npx web-push generate-vapid-keys
# Keep the same key pair across deployments. The frontend fetches the public
# key from GET /api/push/vapid-public-key.
VAPID_PUBLIC_KEY=replace_me
VAPID_PRIVATE_KEY=replace_me
VAPID_SUBJECT=mailto:support@example.com

# Must match BACKEND_NOTIFY_SECRET in the verify-paystack-payment Edge Function.
INTERNAL_NOTIFY_SECRET=replace_with_a_long_random_value
